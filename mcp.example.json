    },
    "exa": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/claude-code-addon-exa"],
      "env": {
        "EXA_API_KEY": ""
      }
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/claude-code-addon-tavily"],
      "env": {
        "TAVILY_API_KEY": ""
      }
    }
  }
}
